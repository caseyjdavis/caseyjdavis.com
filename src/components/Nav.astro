---
// src/components/Nav.astro
---

<nav
  id="main-nav"
  class="flex items-center justify-between px-6 py-4 border-b border-slate-border sticky top-0 z-50 transition-all duration-300"
  style="background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(12px);"
>
  <a href="/" class="font-display font-bold text-white text-base tracking-tight">
    Casey<span class="text-brand-orange">.</span>Davis
  </a>

  <!-- Desktop links -->
  <div class="hidden md:flex items-center gap-6 text-sm text-slate-muted">
    <a href="#services" class="hover:text-white transition-colors">Services</a>
    <a href="#featured-work" class="hover:text-white transition-colors">Work</a>
    <a href="/blog" class="hover:text-white transition-colors">Blog</a>
    <a
      href="/contact"
      class="bg-brand-orange text-white px-4 py-2 rounded font-bold btn-orange-glow hover:bg-orange-500"
    >
      Book a Call
    </a>
  </div>

  <!-- Mobile hamburger -->
  <button
    id="hamburger-btn"
    data-hamburger
    class="md:hidden text-slate-muted hover:text-white"
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>
</nav>

<!-- Mobile drawer -->
<div
  id="mobile-menu"
  data-mobile-menu
  class="hidden md:hidden border-b border-slate-border px-6 py-4 flex flex-col gap-4 text-sm sticky top-[65px] z-40"
  style="background: rgba(15, 23, 42, 0.97); backdrop-filter: blur(12px);"
  aria-hidden="true"
>
  <a href="#services" class="text-slate-muted hover:text-white transition-colors">Services</a>
  <a href="#featured-work" class="text-slate-muted hover:text-white transition-colors">Work</a>
  <a href="/blog" class="text-slate-muted hover:text-white transition-colors">Blog</a>
  <a href="/contact" class="bg-brand-orange text-white px-4 py-2 rounded font-bold text-center">Book a Call</a>
</div>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isOpen));
    menu?.classList.toggle('hidden');
    menu?.setAttribute('aria-hidden', String(isOpen));
  });
</script>
