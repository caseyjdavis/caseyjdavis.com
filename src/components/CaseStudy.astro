---
// src/components/CaseStudy.astro
const stats = [
  { value: '100%', label: 'Cloud' },
  { value: '7', label: 'Stations' },
  { value: '140', label: 'Employees' },
];
---

<section id="featured-work" class="px-6 py-20 md:py-28 bg-slate-dark relative overflow-hidden">
  <!-- Background texture -->
  <div class="absolute inset-0 bg-dot-grid opacity-40 pointer-events-none"></div>

  <p class="text-center text-brand-orange text-xs font-mono font-bold uppercase tracking-[0.2em] mb-14 reveal relative">
    Featured Work
  </p>

  <div class="max-w-3xl mx-auto reveal reveal-delay-1 relative">
    <div
      class="relative bg-midnight rounded-xl p-8 md:p-10 overflow-hidden"
      style="border: 1px solid #334155; border-left: 3px solid #2563eb; box-shadow: 0 0 60px rgba(37, 99, 235, 0.08);"
    >
      <!-- Blue glow accent -->
      <div
        class="absolute top-0 left-0 w-px h-full pointer-events-none"
        style="background: linear-gradient(to bottom, transparent, #2563eb, transparent);"
      ></div>

      <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
        <div>
          <h3 class="font-display text-white font-bold text-xl mb-1">Brighton Fire Rescue</h3>
          <p class="text-slate-muted text-sm">7 stations · 140 employees · Public safety</p>
        </div>
        <span class="bg-blue-950 text-blue-400 text-xs px-3 py-1 rounded border border-brand-blue font-mono">
          Azure Migration
        </span>
      </div>

      <p class="text-slate-muted text-sm leading-relaxed mb-8">
        Migrated a multi-station fire rescue organization from legacy on-premise infrastructure
        to a fully cloud-based environment — improving reliability and access across all locations.
      </p>

      <div class="flex gap-4">
        {stats.map((stat) => (
          <div
            class="flex-1 rounded-lg p-4 text-center"
            style="background: #1e293b; border: 1px solid #334155;"
          >
            <div class="font-display text-3xl font-extrabold text-brand-orange mb-1">{stat.value}</div>
            <div class="text-slate-muted text-xs font-mono uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); } }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('#featured-work .reveal').forEach((el) => observer.observe(el));
</script>
